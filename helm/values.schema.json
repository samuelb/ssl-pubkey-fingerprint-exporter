{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "required": ["create", "annotations", "name", "automount"],
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" },
        "automount": { "type": "boolean" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "port"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "listenHost": { "type": "string" },
    "healthProbes": {
      "type": "object",
      "additionalProperties": true,
      "required": ["livenessPath", "readinessPath"],
      "properties": {
        "livenessPath": { "type": "string", "pattern": "^/" },
        "readinessPath": { "type": "string", "pattern": "^/" }
      }
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string", "minLength": 1 } }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "interval", "scrapeTimeout", "additionalLabels", "selfMonitor", "targets"],
      "properties": {
        "enabled": { "type": "boolean" },
        "interval": { "type": "string", "minLength": 1 },
        "scrapeTimeout": { "type": "string", "minLength": 1 },
        "additionalLabels": { "type": "object" },
        "selfMonitor": { "type": "boolean" },
        "targets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "pathType", "annotations", "hosts", "tls"],
      "properties": {
        "enabled": { "type": "boolean" },
        "pathType": { "enum": ["Exact", "Prefix", "ImplementationSpecific"] },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "tls": { "type": "array", "items": { "type": "object" } }
      }
    },
    "resources": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "serviceMonitor": {
            "properties": {
              "enabled": { "const": true },
              "selfMonitor": { "const": false }
            },
            "required": ["enabled", "selfMonitor"]
          }
        }
      },
      "then": {
        "properties": {
          "serviceMonitor": {
            "properties": { "targets": { "minItems": 1 } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ingress": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "ingress": {
            "properties": {
              "hosts": {
                "minItems": 1,
                "items": {
                  "properties": { "paths": { "minItems": 1 } }
                }
              }
            }
          }
        }
      }
    }
  ]
}
